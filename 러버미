    <!-- Essential Scripts for Layout and Animations -->
    <script>
        // Pagination logic
        var lpCur = 0, lpMax = 3;
        function lpGo(n) {
            document.querySelectorAll(".lp-page").forEach(function(p, i) {
                p.style.display = i === n ? "flex" : "none";
            });
            document.querySelectorAll(".lp-dot").forEach(function(d, i) {
                d.style.width = i === n ? "20px" : "8px";
                d.style.background = i === n ? "#8a8a8a" : "#8a8a8a26";
            });
            lpCur = n;
            var _sp = document.getElementById("lp-page-" + n);
            if(_sp) _sp.scrollTop = 0;
            window.scrollTo(0, 0);
        }
        
        function lpNav(d) {
            lpGo(Math.max(0, Math.min(lpMax - 1, lpCur + d)));
        }

        // Scroll animation logic (IntersectionObserver)
        (function() {
            var obs = new IntersectionObserver(function(es) {
                es.forEach(function(e) {
                    if (e.isIntersecting) {
                        e.target.classList.add("show");
                        obs.unobserve(e.target);
                    }
                });
            }, { threshold: 0.08 });
            
            function scanBlocks() {
                document.querySelectorAll(".block:not(.show)").forEach(function(el) {
                    obs.observe(el);
                });
            }
            
            scanBlocks();
            
            new MutationObserver(function() {
                setTimeout(scanBlocks, 60);
            }).observe(document.body, { childList: true, subtree: true, attributes: true, attributeFilter: ["style", "class"] });
        }());
    </script>
